rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: items
    // Fields: name (string), unit (string), price (number), department (string), 
    //         openingBalance (number), inward (number), outward (number), 
    //         returned (number), currentBalance (number), safetyLimit (number)
    //
    // Collection: suppliers
    // Fields: name (string), totalPurchases (number), totalPayments (number), balance (number)
    //
    // Collection: purchases
    // Fields: date (string), supplierId (string), itemId (string), quantity (number), 
    //         unit (string), unitPrice (number), total (number), paidAmount (number), 
    //         paymentStatus (string), notes (string)
    //
    // Collection: issuances
    // Fields: date (string), jobOrderNo (string), itemId (string), quantity (number), 
    //         unit (string), price (number), total (number), costCenter (string)
    //
    // Collection: loadingManifests
    // Fields: date (string), driverName (string), carNumber (string), destinationType (string), 
    //         clientName (string), orderNumbers (string), products (array), loaderName (string), notes (string)
    //
    // Collection: waste
    // Fields: date (string), itemId (string), quantity (number), unit (string), reason (string), notes (string)
    //
    // Collection: bladeSharpening
    // Fields: date (string), bladeName (string), quantity (number), cost (number), notes (string)
    //
    // Collection: plateSharpening
    // Fields: date (string), plateName (string), quantity (number), cost (number), notes (string)
    //
    // Collection: machineMaintenance
    // Fields: date (string), machineName (string), maintenanceType (string), cost (number), notes (string)
    //
    // Collection: jobLabors
    // Fields: jobId (string), employeeId (string), date (string), hours (number), rate (number), total (number), notes (string)
    //
    // Collection: jobOtherCosts
    // Fields: jobId (string), date (string), description (string), amount (number), notes (string)
    //
    // Collection: deliveryReceipts
    // Fields: date (string), clientName (string), branch (string), address (string), 
    //         phone (string), products (array), productRating (string), teamRating (string), notes (string)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "cfo.moaz@gmail.com" || 
              (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().isAdmin == true));
    }

    function hasPermission(module) {
      return isAuthenticated() && 
             (isAdmin() || getUserData().permissions[module] == true);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
      // Allow new users to create their own initial profile (simplified for first-time use)
      allow create: if isAuthenticated() && request.auth.uid == userId;
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if hasPermission('settings');
    }

    match /warehouses/{warehouseId} {
      allow read: if hasPermission('inventory') || hasPermission('reports');
      allow write: if hasPermission('inventory');
    }

    match /units/{unitId} {
      allow read: if isAuthenticated();
      allow write: if hasPermission('inventory');
    }

    match /costCenters/{costCenterId} {
      allow read: if isAuthenticated();
      allow write: if hasPermission('inventory');
    }

    match /items/{itemId} {
      allow read: if hasPermission('inventory') || hasPermission('reports');
      allow write: if hasPermission('inventory');
    }

    match /suppliers/{supplierId} {
      allow read: if hasPermission('suppliers') || hasPermission('reports');
      allow write: if hasPermission('suppliers');
    }

    match /purchases/{purchaseId} {
      allow read: if hasPermission('purchases') || hasPermission('reports');
      allow write: if hasPermission('purchases');
    }

    match /issuances/{issuanceId} {
      allow read: if hasPermission('inventory') || hasPermission('reports');
      allow write: if hasPermission('inventory');
    }

    match /productionJobs/{jobId} {
      allow read: if hasPermission('production') || hasPermission('reports');
      allow write: if hasPermission('production');
    }

    match /loadingManifests/{manifestId} {
      allow read: if hasPermission('production') || hasPermission('reports');
      allow write: if hasPermission('production');
    }

    match /waste/{wasteId} {
      allow read: if hasPermission('inventory') || hasPermission('reports');
      allow write: if hasPermission('inventory');
    }

    match /bladeSharpening/{id} {
      allow read: if hasPermission('maintenance') || hasPermission('reports');
      allow write: if hasPermission('maintenance');
    }

    match /plateSharpening/{id} {
      allow read: if hasPermission('maintenance') || hasPermission('reports');
      allow write: if hasPermission('maintenance');
    }

    match /machineMaintenance/{id} {
      allow read: if hasPermission('maintenance') || hasPermission('reports');
      allow write: if hasPermission('maintenance');
    }

    match /employees/{id} {
      allow read: if hasPermission('hr') || hasPermission('reports');
      allow write: if hasPermission('hr');
    }

    match /attendance/{id} {
      allow read: if hasPermission('hr') || hasPermission('reports');
      allow write: if hasPermission('hr');
    }

    match /hrTransactions/{id} {
      allow read: if hasPermission('hr') || hasPermission('reports');
      allow write: if hasPermission('hr');
    }

    match /loans/{id} {
      allow read: if hasPermission('hr') || hasPermission('reports');
      allow write: if hasPermission('hr');
    }

    match /payrolls/{id} {
      allow read: if hasPermission('hr') || hasPermission('reports');
      allow write: if hasPermission('hr');
    }

    match /supplierPayments/{id} {
      allow read: if hasPermission('suppliers') || hasPermission('reports');
      allow write: if hasPermission('suppliers');
    }

    match /productionRecords/{id} {
      allow read: if hasPermission('hr') || hasPermission('reports');
      allow write: if hasPermission('hr');
    }

    match /jobLabors/{id} {
      allow read: if hasPermission('production') || hasPermission('reports');
      allow write: if hasPermission('production');
    }

    match /jobOtherCosts/{id} {
      allow read: if hasPermission('production') || hasPermission('reports');
      allow write: if hasPermission('production');
    }

    match /deliveryReceipts/{id} {
      allow read: if hasPermission('production') || hasPermission('reports');
      allow write: if hasPermission('production');
    }

    match /test/{id} {
      allow read: if true;
    }
  }
}
